<style>
  /* Scoped Theme Styles - Adjusted to adapt smoothly to Apache Tiles templates */
  :root {
    --surface:     #ffffff;
    --border:      #e4e7ec;
    --border-2:    #d0d5dd;
    --text:        #101828;
    --text-2:      #475467;
    --text-3:      #98a2b3;
    --accent:      #2174A7; 
    --gray-bg:     #f9fafb;
    --radius:      8px;

    --font:        system-ui, -apple-system, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    --mono:        ui-monospace, Consolas, "Liberation Mono", Menlo, monospace;
  }
  
  /* CRITICAL FIX: Removed min-height: 100vh and absolute padding to prevent breakdown under the template navbar */
  .approvals-body-wrapper {
    font-family: var(--font);
    font-size: 14px;
    color: var(--text);
    padding: 20px 16px;
    -webkit-font-smoothing: antialiased;
    box-sizing: border-box;
  }

  /* ── Card Layout ────────────────────────────────── */
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 1px 3px rgba(16,24,40,0.06);
    margin-top: 10px;
    box-sizing: border-box;
  }

  /* ── Dynamic Filter Toolbar ─────────────────────── */
  .toolbar {
    padding: 12px 16px;
    display: flex;
    align-items: center;
    gap: 10px;
    border-bottom: 1px solid var(--border);
    flex-wrap: wrap;
    background: var(--surface);
  }
  .search-box {
    position: relative;
    flex: 1;
    min-width: 180px;
    max-width: 280px;
  }
  .search-box svg {
    position: absolute;
    left: 10px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-3);
    pointer-events: none;
  }
  .search-box input {
    width: 100%;
    height: 34px;
    padding: 0 12px 0 34px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    font-family: var(--font);
    font-size: 13px;
    color: var(--text);
    background: #f4f5f7;
    outline: none;
    transition: border-color 0.15s, box-shadow 0.15s;
    box-sizing: border-box;
  }
  .search-box input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(33,116,167,0.1);
    background: #fff;
  }
  .row-count {
    margin-left: auto;
    font-size: 12.5px;
    color: var(--text-3);
    white-space: nowrap;
  }

  /* ── DataTables Grid Fixes ──────────────────────── */
  table.dataTable.no-footer,
  table.dataTable {
    border-bottom: none !important;
  }
  .dataTables_wrapper { padding: 0 !important; }
  .dataTables_wrapper .dataTables_length,
  .dataTables_wrapper .dataTables_filter,
  .dataTables_wrapper .dataTables_info { display: none !important; }
  
  table.dataTable {
    width: 100% !important;
    border-collapse: collapse !important;
    margin: 0 !important;
    font-family: var(--font) !important;
    font-size: 13px !important;
  }
  table.dataTable thead th {
    padding: 12px 10px !important;
    border-bottom: 1px solid var(--border) !important;
    border-top: none !important; border-left: none !important; border-right: none !important;
    font-size: 11px !important;
    font-weight: 600 !important;
    text-transform: uppercase !important;
    letter-spacing: 0.5px;
    white-space: nowrap;
  }
  table.dataTable thead th:not(:last-child) {
    border-right: 1px solid rgba(255,255,255,0.2) !important;
  }
  table.dataTable tbody td:not(:last-child) {
    border-right: 1px solid var(--border) !important;
  }
  table.dataTable tbody tr { border-bottom: 1px solid var(--border) !important; }
  table.dataTable tbody tr:hover td { background: #f8fafc !important; }
  table.dataTable tbody td {
    padding: 10px !important;
    vertical-align: middle;
    background: #fff;
    color: var(--text) !important;
  }

  /* ── Typography Utilities ───────────────────────── */
  .cell-mono { font-family: var(--mono); font-size: 12px; color: var(--text); white-space: nowrap; }
  .cell-text { font-size: 12.5px; color: var(--text-2); }
  .disabled-link { color: var(--text-3); font-style: italic; font-size: 12px; }

  /* ── Action Triggers ────────────────────────────── */
  .actions { display: flex; align-items: center; justify-content: center; gap: 6px; }
  .act {
    height: 26px;
    padding: 0 10px;
    border-radius: 4px;
    border: 1px solid var(--border);
    background: var(--surface);
    font-family: var(--font);
    font-size: 11.5px;
    font-weight: 500;
    cursor: pointer;
    color: var(--text-2);
    transition: all 0.15s;
    white-space: nowrap;
    box-sizing: border-box;
  }
  .act:hover { background: #f4f5f7; border-color: var(--border-2); color: var(--text); }
  .act.retry { color: #15803d; border-color: #bbf7d0; background: #f0fdf4; }
  .act.retry:hover { background: #dcfce7; }
  .act.send-back { color: #b45309; border-color: #fef08a; background: #fefce8; }
  .act.send-back:hover { background: #fef9c3; }

  /* ── Footer Elements ────────────────────────────── */
  .table-footer {
    padding: 10px 16px; display: flex; align-items: center; justify-content: space-between;
    border-top: 1px solid var(--border); background: var(--gray-bg); gap: 12px; flex-wrap: wrap;
  }
  .footer-left { font-size: 12.5px; color: var(--text-2); }
  .footer-left strong { color: var(--text); }
  .pg { display: flex; align-items: center; gap: 3px; }
  .pg-btn {
    min-width: 28px; height: 28px; padding: 0 4px; border: 1px solid var(--border);
    border-radius: 4px; background: var(--surface); font-family: var(--font);
    font-size: 12px; color: var(--text-2); cursor: pointer;
    display: flex; align-items: center; justify-content: center; transition: all 0.15s;
    box-sizing: border-box;
  }
  .pg-btn:hover:not(:disabled):not(.active) { background: #f4f5f7; border-color: var(--border-2); color: var(--text); }
  .pg-btn.active { background: var(--accent); border-color: var(--accent); color: #fff; font-weight: 600; }
  .pg-btn:disabled { opacity: 0.4; cursor: default; }
</style>







